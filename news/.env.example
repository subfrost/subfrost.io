# SUBFROST News — environment

# Postgres (Cloud SQL instance subfrost-postgres, database "news")
DATABASE_URL="postgresql://news:PASSWORD@HOST:5432/news?schema=public&sslmode=require"

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET="change-me"
# Public URL of this service (used by Auth.js for callbacks)
AUTH_URL="https://news.subfrost.io"
NEXTAUTH_URL="https://news.subfrost.io"

# Bootstrap admin (consumed by prisma/seed.ts; safe to unset after first run)
BOOTSTRAP_ADMIN_EMAIL="ops@subfrost.io"
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_ADMIN_NAME="SUBFROST Admin"
