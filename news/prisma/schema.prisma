generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// IAM
// ============================================

enum Role {
  ADMIN // full control: manage users + all articles
  EDITOR // publish/unpublish + edit any article
  AUTHOR // create + edit own drafts, submit for review
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(AUTHOR)
  active       Boolean   @default(true)
  articles     Article[] @relation("AuthoredArticles")
  revisions    Revision[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// ============================================
// CONTENT
// ============================================

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  // Short summary shown in previews / homepage cards
  excerpt     String        @default("")
  // Full body in Markdown
  body        String        @default("")
  coverImage  String? // URL of cover image
  status      ArticleStatus @default(DRAFT)
  featured    Boolean       @default(false) // surfaced on subfrost.io homepage

  author      User          @relation("AuthoredArticles", fields: [authorId], references: [id])
  authorId    String
  tags        Tag[]         @relation("ArticleTags")
  revisions   Revision[]

  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
  @@index([authorId])
}

model Tag {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  articles Article[] @relation("ArticleTags")
}

// Immutable snapshot of an article body each time it is saved, for history/audit
model Revision {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  title     String
  body      String
  editor    User?    @relation(fields: [editorId], references: [id])
  editorId  String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
}
