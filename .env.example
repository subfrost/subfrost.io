# Subfrost.io Environment Configuration
# Copy to .env and fill in values

# ============================================
# Database (Cloud SQL for production)
# ============================================
# Local development:
# DATABASE_URL="postgresql://subfrost:subfrost_dev_password@localhost:5432/subfrost"

# Cloud SQL (production):
# DATABASE_URL="postgresql://subfrost:<password>@/subfrost?host=/cloudsql/<project>:<region>:<instance>"
DATABASE_URL="postgresql://subfrost:subfrost_dev_password@localhost:5432/subfrost"

# ============================================
# Redis (Cloud Memorystore for production)
# ============================================
# Local development:
# REDIS_URL="redis://localhost:6379"

# Cloud Memorystore (production):
# REDIS_URL="redis://10.x.x.x:6379"
REDIS_URL="redis://localhost:6379"

# ============================================
# Alkanes RPC Configuration
# ============================================
# Default Subfrost RPC endpoint
ALKANES_RPC_URL="https://mainnet.subfrost.io/v4/subfrost"

# ============================================
# Network Configuration
# ============================================
# Options: mainnet, testnet, signet, regtest
NEXT_PUBLIC_NETWORK="mainnet"

# Optional homepage ticker row below the protocol stats.
# Defaults off unless explicitly set to "true".
NEXT_PUBLIC_SHOW_HERO_MARKET_TICKER="false"

# ============================================
# Node Environment
# ============================================
NODE_ENV="development"

# ============================================
# Admin API Secret
# ============================================
# Secret for authenticating admin API endpoints (/api/admin/*)
# Use a GitHub repository secret for production
ADMIN_SECRET="change-me-in-production"

# ============================================
# CMS / Admin auth (the /admin newsroom)
# ============================================
# HMAC secret for signing the admin session cookie. Must be set.
AUTH_SECRET="change-me-in-dev"
# Public base URL used to build links in emails (invite / reset).
CMS_BASE_URL="http://localhost:3000"
# Public GCS bucket for CMS image uploads (avatars / covers).
CMS_BUCKET="subfrost-cms"
# Optional local visual QA: use production's public article feed on localhost
# without connecting to the production database.
# ARTICLE_PREVIEW_API_URL="https://subfrost.io/api/articles"
# Seed admin (prisma/cms-seed.ts)
SEED_ADMIN_EMAIL="ashik@subfrost.io"
SEED_ADMIN_PW=""

# ============================================
# Email (Resend) — invite / password-reset / verification
# ============================================
# Shared with subfrost-mobile / subkube. Verified sender domain: mail.subfrost.io
RESEND_API_KEY=""
EMAIL_FROM="SUBFROST <noreply@mail.subfrost.io>"

# ============================================
# Documenso (e-sign document sender) — /admin/documents
# ============================================
# When unset, the document sender runs in local mock mode: envelopes are created
# with LOCAL-* ids, state flips locally, and no real emails/signatures occur, so
# the admin UI is fully reviewable before Documenso is wired up. Set all three to
# go live (store the key + webhook secret in Secret Manager for production).
DOCUMENSO_API_URL=""
DOCUMENSO_API_KEY=""
# Shared secret Documenso echoes in the X-Documenso-Secret header on every
# webhook delivery to /api/webhooks/documenso (NOT an HMAC — a plain secret).
DOCUMENSO_WEBHOOK_SECRET=""

# Salt for hashing reviewer-session IPs (delegated compliance reviewer links).
# Rotate to make stored IP hashes unrecoverable. Defaults to a placeholder.
SESSION_IP_SALT=""

# ============================================
# Referral API (cross-service)
# ============================================
# Shared service key for the referral/invite-code API (/api/invite-codes/*),
# which subfrost-app calls server-to-server. The endpoints fail closed (503)
# when unset. Store in Secret Manager for production.
REFERRAL_API_KEY="change-me-in-production"

# ============================================
# Error-report dashboard (cross-service)
# ============================================
# Bearer token for /admin/errors to query subfrost-app's
# GET /api/admin/error-reports server-to-server. The SAME value must be set as
# ERROR_REPORTS_SERVICE_TOKEN on the subfrost-app deployment. Page shows a
# "not configured" notice when unset. Store in Secret Manager for production.
ERROR_REPORTS_SERVICE_TOKEN="change-me-in-production"
# Override the app API base for staging/local (default https://app.subfrost.io)
# ERROR_REPORTS_API_BASE="http://localhost:3000"

# ============================================
# frBTC volume indexer (Financials > Revenue → BTC fee source)
# ============================================
# JSON-RPC endpoint of the dedicated frBTC volume metashrew indexer
# (crates/frbtc-volume-indexer, its own rockshrew-mono instance). When set AND
# reachable, the Revenue tab's BTC wrap/unwrap fee series is read on-chain via
# the `metashrew_view` methods frbtc_volume_range / frbtc_volume_tip. When unset
# (or unreachable), it falls back to the WrapTransaction/UnwrapTransaction tables.
# Leave blank to keep the table-based behavior.
FRBTC_INDEXER_RPC_URL=

# JSON-RPC endpoint of the SECOND frBTC venue's indexer — frBTC on BRC20-Prog
# (crates/frbtc-brc20-volume-indexer, its own rockshrew-mono over Bitcoin L1).
# Same frbtc_volume_range / frbtc_volume_tip views. When set AND reachable it
# lights up the BRC20-Prog venue on /admin Revenue (cumulative + per-venue split)
# and makes it the source of truth for the `brc20` source on the public /volume
# page (replacing the request-time esplora scan). Unset ⇒ venue reads 0; the
# public page falls back to the legacy scan. Leave blank until the route is live.
FRBTC_BRC20_INDEXER_RPC_URL=

# ============================================
# Marketing > Site analytics (GA4 Data API)
# ============================================
# Optional — the dashboard shows a "not configured" banner until both are set.
GA4_PROPERTY_ID=
GA_SERVICE_ACCOUNT_JSON=

# ============================================
# IPROYAL residential proxy (Financials > Treasury → BSC RPC)
# ============================================
# Optional. When set, the treasury BSC-RPC path (lib/financials/treasury/source/
# bsc-rpc.ts) tunnels the tlsfetch TCP leg through this residential HTTP CONNECT
# proxy so NodeReal (behind Cloudflare) sees a clean IP instead of a blocked
# datacenter NAT. Format: http://USER:PASS@geo.iproyal.com:12321
# Leave blank for direct dial (dev/local). In prod it's the k8s Secret iproyal-proxy.
IPROYAL_PROXY=

# ============================================
# Compliance program register (/admin/compliance)
# ============================================
# The registration facts (legal entity, BSA ID, tracking, compliance officer)
# are NOT configured via env. They live in a DB-backed singleton editable in the
# admin UI (Compliance → Registration), so the confidential values stay out of
# this public repo and out of the environment. To set them from a script/job at
# runtime, see scripts/set-compliance-register.mjs.
