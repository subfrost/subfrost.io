generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SUBFROST METRICS MODELS
// ============================================

// Stores aggregated BTC locked data at specific block heights
model BtcLockedSnapshot {
  id          String  @id @default(cuid())
  blockHeight Int
  blockHash   String?

  // BTC locked in the subfrost address
  btcLocked Float // BTC as decimal
  satoshis  BigInt // Satoshis
  utxoCount Int // Number of UTXOs

  // Timestamp of the block
  blockTime DateTime?

  // When we computed this snapshot
  createdAt DateTime @default(now())

  @@index([blockHeight])
  @@index([createdAt])
}

// Stores frBTC total supply at specific block heights
model FrbtcSupplySnapshot {
  id          String  @id @default(cuid())
  blockHeight Int
  blockHash   String?

  // frBTC total supply
  frbtcIssued    Float // BTC as decimal
  rawSupply      String // Raw supply as string (bigint)
  adjustedSupply String // Adjusted supply as string (bigint)

  // Timestamp of the block
  blockTime DateTime?

  // When we computed this snapshot
  createdAt DateTime @default(now())

  @@index([blockHeight])
  @@index([createdAt])
}

// Stores wrap transaction history
model WrapTransaction {
  id          String  @id @default(cuid())
  txid        String  @unique
  blockHeight Int
  blockHash   String?

  // Transaction details
  amount           String // Amount in satoshis as string (bigint)
  senderAddress    String  @default("")
  recipientAddress String?

  // Timestamp
  timestamp DateTime

  // Status
  confirmed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blockHeight])
  @@index([senderAddress])
  @@index([confirmed])
}

// Stores unwrap transaction history
model UnwrapTransaction {
  id          String  @id @default(cuid())
  txid        String  @unique
  blockHeight Int
  blockHash   String?

  // Transaction details
  amount           String // Amount in satoshis as string (bigint)
  senderAddress    String?
  recipientAddress String  @default("")

  // Timestamp
  timestamp DateTime

  // Status
  confirmed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blockHeight])
  @@index([recipientAddress])
  @@index([confirmed])
}

// Stores the last processed block height for each data type
model SyncState {
  dataType String @id

  // Last processed block height
  lastBlockHeight Int @default(0)

  // Last processed transaction ID (for pagination)
  lastTxid String?

  // Aggregated totals (stored as strings for bigint support)
  totalWrapped   String @default("0")
  totalUnwrapped String @default("0")
  wrapCount      Int    @default(0)
  unwrapCount    Int    @default(0)

  updatedAt DateTime @updatedAt
}

// ============================================
// METRICS AGGREGATION
// ============================================

// Daily aggregated metrics for charts
model DailyMetrics {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date

  // BTC locked metrics
  btcLockedOpen  BigInt // Opening BTC locked for the day
  btcLockedHigh  BigInt // Highest BTC locked
  btcLockedLow   BigInt // Lowest BTC locked
  btcLockedClose BigInt // Closing BTC locked

  // frBTC supply metrics
  frbtcSupplyOpen  BigInt
  frbtcSupplyHigh  BigInt
  frbtcSupplyLow   BigInt
  frbtcSupplyClose BigInt

  // Transaction counts
  wrapCount    Int    @default(0)
  unwrapCount  Int    @default(0)
  wrapVolume   BigInt @default(0) // Total BTC wrapped
  unwrapVolume BigInt @default(0) // Total BTC unwrapped

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// Cache for computed API responses
model ApiCache {
  key       String   @id
  value     String   @db.Text // JSON-encoded value
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ============================================
// LIVE STREAMING MODELS
// ============================================

model StreamSession {
  id           String          @id @default(cuid())
  streamKey    String          @unique
  title        String          @default("Live Stream")
  status       String          @default("created") // created | live | ended
  screenHlsUrl String?
  cameraHlsUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  captions     StreamCaption[]
  chatMessages ChatMessage[]

  @@index([status])
}

model StreamCaption {
  id             String        @id @default(cuid())
  sessionId      String
  session        StreamSession @relation(fields: [sessionId], references: [id])
  textOriginal   String
  textTranslated String?
  languageFrom   String        @default("en")
  languageTo     String?
  timestamp      Float
  duration       Float?
  createdAt      DateTime      @default(now())

  @@index([sessionId, timestamp])
}

model ChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  session   StreamSession @relation(fields: [sessionId], references: [id])
  nickname  String
  message   String
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

// ============================================
// CMS / NEWS PLATFORM (subfrost.io/admin + /articles)
// ============================================

enum Role {
  ADMIN // full control: manage users + all articles + API keys
  EDITOR // publish/unpublish + edit any article
  AUTHOR // create + edit own drafts, submit for review
  STAFF // bundle vazio: só grants granulares extras (personas least-privilege)
}

// Fine-grained capabilities. A user's effective privileges are the union of the
// default bundle for their Role (see lib/cms/privileges.ts) plus any extra
// grants stored in User.privileges. API-key scopes are a subset of these.
// Privileges are namespaced `domain.action` string codes managed by the IAM
// registry in lib/cms/iam/registry.ts (not a Postgres enum — the registry is the
// single source of truth, with a dependency graph and English descriptions).

// Token kinds for emailed, single-use links (Resend-delivered).
enum TokenPurpose {
  INVITE // new user sets their own password
  PASSWORD_RESET // self-service forgot-password
  EMAIL_VERIFY // confirm email ownership
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum Locale {
  en
  zh
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime? // set when ownership confirmed (invite/verify flow)
  name           String?
  passwordHash   String
  role           Role      @default(AUTHOR)
  active         Boolean   @default(true)
  // Extra capability grants beyond the role's default bundle.
  privileges     String[]  @default([])
  // Public author profile
  avatarUrl      String? // GCS URL
  bio            String?
  twitter        String?
  status         String? // optional self-set status line
  lastSeenAt     DateTime? // presence: last authenticated activity
  // Two-factor (TOTP)
  totpSecret     String? // base32 secret, present once enrollment starts
  totpEnabled    Boolean   @default(false)
  totpVerifiedAt DateTime?
  // Bumped on password change / forced logout to invalidate all live sessions.
  tokenVersion   Int       @default(0)

  articles      Article[]          @relation("AuthoredArticles")
  revisions     Revision[]
  apiKeys       ApiKey[]
  sessions      Session[]
  recoveryCodes TotpRecoveryCode[]
  auditLogs     AuditLog[]         @relation("AuditActor")
  payee         Payee?             @relation
  reviewLinks   ReviewLink[]       @relation("ReviewLinkCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// Server-side session records backing the signed cookie. The cookie JWT carries
// a `jti` matching tokenHash; currentUser() rejects revoked/expired sessions so
// "sign out everywhere" and password-change invalidation take effect immediately.
model Session {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  tokenHash      String   @unique // sha-256 of the session jti
  ip             String?
  userAgent      String?
  // TLS fingerprint (JA4) of the client, injected by the tlsd ingress as a
  // request header at TLS termination. Null until the fingerprint-capable
  // ingress fronts this app — degrades gracefully.
  tlsFingerprint String?
  createdAt      DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  expiresAt      DateTime
  revoked        Boolean  @default(false)

  @@index([userId])
  @@index([tokenHash])
}

// Single-use TOTP recovery codes (sha-256 hashed), generated when 2FA is enabled.
model TotpRecoveryCode {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  codeHash  String // sha-256 of the code
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Append-only audit trail for IAM, auth, and key events.
model AuditLog {
  id        String   @id @default(cuid())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId   String?
  action    String // login, logout, login_2fa, create_user, update_user, delete_user, change_password, key_mint, key_revoke, totp_enabled, totp_disabled
  target    String? // affected resource id/email
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action])
}

// Emailed single-use tokens for invite / password-reset / email-verify flows.
model VerificationToken {
  id        String       @id @default(cuid())
  email     String
  userId    String? // null for invites of not-yet-created users
  tokenHash String       @unique // sha-256 of the raw token
  purpose   TokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([email])
  @@index([tokenHash])
}

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  coverImage    String? // GCS URL
  status        ArticleStatus @default(DRAFT)
  featured      Boolean       @default(false) // surfaced on homepage
  // Default/source locale for the article
  primaryLocale Locale        @default(en)

  author       User                 @relation("AuthoredArticles", fields: [authorId], references: [id])
  authorId     String
  tags         Tag[]                @relation("ArticleTags")
  translations ArticleTranslation[]
  revisions    Revision[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
  @@index([authorId])
}

// Per-locale content for an article (EN / ZH). An article may have one or both.
model ArticleTranslation {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  locale    Locale
  title     String
  excerpt   String   @default("")
  body      String   @default("") // Markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, locale])
  @@index([locale])
}

model Tag {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  articles Article[] @relation("ArticleTags")
}

// Immutable snapshot per save, for history/audit.
model Revision {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  locale    Locale
  title     String
  body      String
  editor    User?    @relation(fields: [editorId], references: [id])
  editorId  String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
}

// Email subscribers for news/article updates.
model ArticleSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  locale       Locale   @default(en)
  source       String   @default("articles_page")
  active       Boolean  @default(true)
  subscribedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([locale])
}

// Bearer keys for the admin upload API (POST /api/admin/articles).
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  hashedKey  String    @unique // sha-256 of the token
  prefix     String // first 8 chars, shown in UI for identification
  // Capability scopes for this key — always a subset of the owner's effective
  // privileges at mint time. The verifier caps the key's authority to this set.
  scopes     String[]  @default([])
  createdBy  User      @relation(fields: [userId], references: [id])
  userId     String
  lastUsedAt DateTime?
  expiresAt  DateTime? // optional expiry
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([hashedKey])
}

// ============================================
// REFERRAL / INVITE CODES
// Consolidated from subfrost-app (graph only: codes + redemptions keyed by
// taproot address; wallet-users stay in subfrost-app).
// ============================================

model InviteCode {
  id                  String   @id @default(cuid())
  code                String   @unique // stored uppercase
  description         String?
  isActive            Boolean  @default(true)
  ownerTaprootAddress String?
  createdAt           DateTime @default(now())

  // Hierarchy: leader → sub-leader (null for top-level leader codes)
  parentCodeId String?
  parentCode   InviteCode?  @relation("CodeHierarchy", fields: [parentCodeId], references: [id])
  childCodes   InviteCode[] @relation("CodeHierarchy")

  redemptions InviteCodeRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([parentCodeId])
  @@index([ownerTaprootAddress])
}

model InviteCodeRedemption {
  id             String     @id @default(cuid())
  code           InviteCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  codeId         String
  taprootAddress String
  segwitAddress  String?
  taprootPubkey  String?
  redeemedAt     DateTime   @default(now())
  updatedAt      DateTime?  @updatedAt

  @@unique([codeId, taprootAddress])
  @@index([taprootAddress])
  @@index([redeemedAt])
}

// FUEL allocations per address (growth rewards). One row per address.
model FuelAllocation {
  id        String   @id @default(cuid())
  address   String   @unique
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([amount])
}

// Editable per-address profile metadata, keyed by the (taproot) address itself.
// Exists independently of FUEL/referral rows so any address can be annotated.
model AddressProfile {
  address   String   @id
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// COMPLIANCE — KYC (F2-A)
// ============================================

enum KycProvider {
  PERSONA
  STRIPE_IDENTITY
  SUMSUB
}

enum RiskScore {
  LOW
  MEDIUM
  HIGH
}

enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum KycDecision {
  APPROVE
  REJECT
  REVIEW
}

model KycIntake {
  id            String           @id @default(cuid())
  externalId    String?          @unique // id at the provider (Stripe vs_...); unique for idempotent sync
  customerEmail String
  customerName  String
  provider      KycProvider
  riskScore     RiskScore
  status        KycStatus        @default(PENDING)
  submittedAt   DateTime
  providerData  Json? // synced provider summary (verdict, lastError, document, extracted) — SP-2
  createdAt     DateTime         @default(now())
  dispositions  KycDisposition[]
  payees        Payee[]

  @@index([status])
}

model KycDisposition {
  id       String      @id @default(cuid())
  intakeId String
  intake   KycIntake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  decision KycDecision
  notes    String?
  by       String // operator email
  at       DateTime    @default(now())

  @@index([intakeId])
}

// ============================================
// COMPLIANCE — FinCEN / BSA (F2-B)
// ============================================

enum FincenFormType {
  FORM107
  SAR
  CTR
}

enum FincenSubmissionStatus {
  QUEUED
  ACCEPTED
  REJECTED
}

model FincenDraft {
  id          String             @id @default(cuid())
  type        FincenFormType
  data        Json // validated by zod in lib/fincen/schemas.ts
  updatedBy   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  submissions FincenSubmission[]

  @@index([type])
}

model FincenSubmission {
  id          String                 @id @default(cuid())
  draftId     String
  draft       FincenDraft            @relation(fields: [draftId], references: [id], onDelete: Cascade)
  type        FincenFormType
  trackingId  String // LOCAL-<...> until real BSA transport
  status      FincenSubmissionStatus @default(QUEUED)
  message     String?
  submittedBy String
  submittedAt DateTime               @default(now())

  @@index([draftId])
}

// ============================================
// COMPLIANCE — MTL licensing (F2-C)
// ============================================

enum MtlStatus {
  AGENT_OF_STRIPE
  REGISTERED
  FILED_PENDING
  EXEMPT
  NOT_YET_NEEDED
  NEEDS_FILING
}

model MtlEntry {
  state         String    @id // 2-letter jurisdiction code (incl. DC)
  name          String
  status        MtlStatus @default(NOT_YET_NEEDED)
  nextFilingDue String?
  portalUrl     String?
  notes         String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

// ============================================
// BILLING — Stripe console (F2-D)
// ============================================

// Money guardrail (ACH + refund) — used in BOTH seed and live modes.
enum StripeMoneyKind {
  ACH_TRANSFER
  REFUND
}

enum StripeMoneyStatus {
  QUEUED
  CONFIRMED
  CANCELED
}

model StripeMoneyIntent {
  id           String            @id @default(cuid())
  kind         StripeMoneyKind
  direction    String? // "in" | "out" (ACH)
  amount       Int // cents
  counterparty String? // ACH
  reference    String? // chargeId/invoiceId (refund)
  memo         String?
  status       StripeMoneyStatus @default(QUEUED)
  requestedBy  String
  requestedAt  DateTime          @default(now())
  decidedBy    String?
  decidedAt    DateTime?
}

// Low-risk overlays — layered onto reads only in seed mode (interactive demo).
model StripeCardControl {
  cardId String   @id
  state  String // "active" | "paused" | "canceled"
  by     String
  at     DateTime @default(now())
}

model StripeDisputeEvidence {
  id            String   @id @default(cuid())
  disputeId     String
  evidence      String?
  evidenceFiles String[]
  by            String
  at            DateTime @default(now())
}

enum StripePromoType {
  PERCENT
  AMOUNT
}

model StripePromoCode {
  id             String          @id @default(cuid())
  code           String          @unique
  type           StripePromoType
  value          Int // percent or cents
  maxRedemptions Int?
  expiresAt      DateTime?
  active         Boolean         @default(true)
  by             String
  createdAt      DateTime        @default(now())
}

model StripeSubscriptionAction {
  id             String   @id @default(cuid())
  subscriptionId String
  action         String // "cancel" | "pause" | "resume" | "change_tier"
  note           String?
  by             String
  at             DateTime @default(now())
}

// Application/onboarding tracker — pure Postgres, no Stripe.
enum StripeApplicationStatus {
  NOT_STARTED
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model StripeApplication {
  id        String                  @id @default(cuid())
  product   String                  @unique // "treasury" | "issuing" | "offramp"
  status    StripeApplicationStatus @default(NOT_STARTED)
  notes     String?
  updatedBy String
  updatedAt DateTime                @updatedAt
}

// SP-4: append-only-ish log of received Stripe webhook events. PII-free: only a
// non-sensitive summary is stored; full detail lives in the Stripe dashboard.
model StripeWebhookEvent {
  id            String   @id // Stripe event id (evt_...) = natural PK → idempotency
  type          String // e.g. "identity.verification_session.verified"
  apiVersion    String?
  stripeCreated DateTime // event.created
  receivedAt    DateTime @default(now())
  status        String   @default("received") // received | processed | ignored | failed
  handled       Boolean  @default(false) // did a domain handler act on it?
  error         String?
  objectType    String? // event.data.object.object e.g. "charge","payout"
  objectId      String?
  objectStatus  String? // object.status (non-PII)
  amount        Int? // cents, when present
  currency      String?
  reason        String? // dispute / rejection reason (non-PII)

  @@index([type])
  @@index([receivedAt])
  @@index([status])
}

// ============================================
// FINANCIALS — Accounting (SP-1: DIESEL ledger)
// ============================================

enum PayeeType {
  PERSON
  ORG
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
}

enum PaymentSource {
  ONCHAIN
  MANUAL
}

model Payee {
  id           String     @id @default(cuid())
  name         String
  type         PayeeType  @default(PERSON)
  kycIntakeId  String? // optional link to a KYC'd identity (Stripe Identity)
  kycIntake    KycIntake? @relation(fields: [kycIntakeId], references: [id])
  notes        String?
  userId       String?    @unique // optional 1:1 link to a team-member User
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  agreementUrl String? // contract/agreement PDF (CMS_BUCKET)
  createdAt    DateTime   @default(now())
  invoices     Invoice[]
  envelopes    Envelope[] // e-sign envelopes (legal paperwork) tied to this payee

  @@index([name])
}

model Invoice {
  id           String          @id @default(cuid())
  ref          String          @unique // human ref e.g. INV-014
  payeeId      String
  payee        Payee           @relation(fields: [payeeId], references: [id])
  description  String
  amountUsd    Float
  amountDiesel Float? // expected DIESEL (optional; actual comes from payments)
  issuedAt     DateTime
  status       InvoiceStatus   @default(OPEN)
  pdfUrl       String? // GCS object (CMS_BUCKET)
  createdAt    DateTime        @default(now())
  payments     DieselPayment[]

  @@index([payeeId])
  @@index([status])
}

model DieselPayment {
  id               String        @id @default(cuid())
  txid             String // bitcoin txid of the DIESEL transfer
  vout             Int?
  amountDiesel     Float
  recipientAddress String
  paidAt           DateTime // block time
  blockHeight      Int?
  invoiceId        String?
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id])
  source           PaymentSource @default(MANUAL)
  createdAt        DateTime      @default(now())

  @@unique([txid, vout]) // idempotent vs SP-2 ingestion
  @@index([invoiceId])
}

// ============================================
// DOCUMENTS — e-sign envelopes (Documenso)
// ============================================
//
// The document-sender / legal-contract surface ported from subfrost-admin.
// `kind` + `status` hold the lowercase string vocabularies defined in
// lib/esign/types.ts (the state machine is the source of truth, not Prisma
// enums) — mirrors how FincenDraft stores zod-validated JSON. `recipients`,
// `attachment`, and `fields` are JSON blobs matching the EnvelopeRecord shape.
model Envelope {
  id                   String    @id @default(cuid())
  kind                 String // EnvelopeKind (lib/esign/types.ts)
  subject              String
  message              String?
  status               String    @default("draft") // EnvelopeStatus
  externalDocumentId   String? // Documenso document id (or LOCAL-<...> in mock mode)
  recipients           Json // Recipient[]
  attachment           Json? // DocumentAttachment (GCS object name, sha256, …)
  fields               Json? // Field[] — drag-placed signature fields
  signingOrderEnabled  Boolean   @default(false)
  expiresAt            DateTime?
  sentAt               DateTime?
  completedAt          DateTime?
  voidedAt             DateTime?
  voidReason           String?
  lastResendAt         DateTime?
  fieldsAppliedAt      DateTime?
  fieldsAppliedCount   Int       @default(0)
  signedDocumentObject String? // GCS object name of the fully-signed PDF
  appliedEventIds      String[]  @default([]) // bounded webhook-dedup window
  notes                String?
  // Optional link to the payee this paperwork belongs to — powers the
  // "legal paperwork they've signed" section of the payee profile.
  payeeId              String?
  payee                Payee?    @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  createdBy            String // operator email
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([payeeId])
  @@index([externalDocumentId])
  @@index([createdAt])
}

// ============================================
// COMPLIANCE — delegated external-reviewer links
// ============================================
//
// A reviewer (no platform account) is handed a password-protected, scoped,
// expiring URL. They authenticate at /compliance/review/<token> and get a
// separate review-session cookie granting read-only access to the compliance
// surfaces named by `scope`. Ported from subfrost-admin lib/reviews.ts.
model ReviewLink {
  id              String          @id @default(cuid())
  token           String          @unique // the value in the URL
  passwordHash    String // bcrypt
  reviewerLabel   String
  reviewerEmail   String?
  scope           String // ReviewScope: compliance-full | fincen-only | kyc-only
  notes           String?
  createdByUserId String? // operator who minted the link (nullable so the link survives creator deletion)
  createdBy       User?           @relation("ReviewLinkCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedByUserId String?
  sessions        ReviewSession[]

  @@index([token])
}

model ReviewSession {
  id           String     @id @default(cuid())
  reviewLinkId String
  reviewLink   ReviewLink @relation(fields: [reviewLinkId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique // sha-256 of the session cookie value
  userAgent    String?
  ipHash       String? // salted hash — never store raw IPs
  createdAt    DateTime   @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime   @default(now())
  pagesViewed  String[]   @default([])

  @@index([reviewLinkId])
  @@index([tokenHash])
}

// ============================================
// FINANCIALS — equity / cap table (409A)
// ============================================

enum ShareClassType {
  COMMON
  PREFERRED
}

enum HolderType {
  PERSON
  ENTITY
}

// SAFEs, token agreements, notes — convertible / investment instruments. One
// register with a type discriminator; SAFE-specific term fields are nullable for
// non-SAFE types.
enum InstrumentType {
  SAFE
  TOKEN_WARRANT
  TOKEN_SIDE_LETTER
  SAFT
  CONVERTIBLE_NOTE
  OTHER
}

enum InstrumentStatus {
  OUTSTANDING
  CONVERTED
  CANCELLED
}

enum SafeKind {
  POST_MONEY
  PRE_MONEY
}

model ShareClass {
  id               String         @id @default(cuid())
  name             String // e.g. "Common Stock"
  type             ShareClassType @default(COMMON)
  authorizedShares Int
  parValue         Float?
  notes            String?
  createdAt        DateTime       @default(now())
  holdings         ShareHolding[]

  @@index([type])
}

model Shareholder {
  id          String         @id @default(cuid())
  name        String
  type        HolderType     @default(PERSON)
  email       String?
  userId      String? // optional link to a team-member User (loose ref)
  payeeId     String? // optional link to a Payee identity (loose ref)
  notes       String?
  createdAt   DateTime       @default(now())
  holdings    ShareHolding[]
  instruments Instrument[]

  @@index([name])
}

model ShareHolding {
  id            String      @id @default(cuid())
  shareholderId String
  shareholder   Shareholder @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
  shareClassId  String
  shareClass    ShareClass  @relation(fields: [shareClassId], references: [id])
  shares        Int
  issuedAt      DateTime
  certificateNo String?
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([shareholderId])
  @@index([shareClassId])
}

model Instrument {
  id             String           @id @default(cuid())
  type           InstrumentType   @default(SAFE)
  status         InstrumentStatus @default(OUTSTANDING)
  investorName   String
  investorEntity String?
  investorEmail  String?
  shareholderId  String? // optional link to the investor's Shareholder identity
  shareholder    Shareholder?     @relation(fields: [shareholderId], references: [id], onDelete: SetNull)
  amountUsd      Float
  signedAt       DateTime
  // SAFE / note terms (null for token agreements)
  safeKind       SafeKind?
  valuationCap   Float?
  discountRate   Float? // 0..1, e.g. 0.20
  mfn            Boolean          @default(false)
  proRata        Boolean          @default(false)
  // convertible note terms
  interestRate   Float?
  maturityDate   DateTime?
  // token agreement terms
  tokenPct       Float? // % of token supply
  tokenAmount    Float?
  // binding-document linkage: an uploaded signed PDF and/or a linked e-sign
  // Envelope (Documents system). envelopeId is a loose ref resolved on read.
  pdfUrl         String?
  envelopeId     String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([type])
  @@index([status])
  @@index([shareholderId])
}

// ============================================
// FINANCIALS — balance sheet (manual GL line items)
// ============================================
//
// Computed lines (treasury USD, open-invoice AR, outstanding SAFE proceeds,
// issued common equity) are derived at render time. These rows are the manual
// additions/overrides the operator enters to complete the statement.
enum BalanceSheetSection {
  ASSET
  LIABILITY
  EQUITY
}

model BalanceSheetItem {
  id        String              @id @default(cuid())
  section   BalanceSheetSection
  label     String
  amountUsd Float
  sortOrder Int                 @default(0)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([section])
}
